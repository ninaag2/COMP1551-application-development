using System.Windows.Forms;
using System.Xml.Linq;

namespace coursework
{
    public partial class Form1 : Form
    {
        // This list will act as the required data structure for holding objects of derived classes polymorphically
        private System.Collections.Generic.List<Person> _peopleList = new System.Collections.Generic.List<Person>();

        public Form1()
        {
            InitializeComponent();
            
            // Thiết lập ComboBox "Loc theo Role" trên màn hình chính
            comboBox1.Items.Clear();
            comboBox1.Items.Add("All"); // Thêm All để xem tất cả
            comboBox1.Items.Add("Teacher");
            comboBox1.Items.Add("Admin");
            comboBox1.Items.Add("Student");
            comboBox1.DropDownStyle = ComboBoxStyle.DropDownList;
            comboBox1.SelectedIndex = 0; // Mặc định chọn All
        }

        private void btnAddNew_Click(object sender, EventArgs e)
        {
            AddPersonForm form = new AddPersonForm();
            if (form.ShowDialog() == DialogResult.OK)
            {
                var data = form.GetInputData();
                Person newPerson = null;

                // Simple parser using Polymorphism depending on the Role passed from UI
                string role = data.Role.ToLower();
                double salary = 0;
                double.TryParse(data.Info.Split(' ')[0], out salary); // First info part can be salary

                if (role == "teacher")
                    newPerson = new Teacher(data.Name, data.Tel, data.Email, salary, "Subject1", "Subject2");
                else if (role == "admin")
                    newPerson = new Admin(data.Name, data.Tel, data.Email, salary, true, 40);
                else // student or default
                    newPerson = new Student(data.Name, data.Tel, data.Email, "Subject1", "Subject2", "Subject3");

                _peopleList.Add(newPerson); // Storing the object in the data structure

                dataGridView1.Rows.Add(
                    newPerson.Name,
                    newPerson.Telephone,
                    newPerson.Email,
                    newPerson.Role,
                    data.Info // Can be extracted from specific properties of the subclasses if preferred
                );
            }
        }

        private void btnEdit_Click(object sender, EventArgs e)
        {
            if (dataGridView1.CurrentRow == null) return;
            
            DataGridViewRow row = dataGridView1.CurrentRow;

            string name = row.Cells[0].Value?.ToString() ?? "";
            string tel = row.Cells[1].Value?.ToString() ?? "";
            string email = row.Cells[2].Value?.ToString() ?? "";
            string role = row.Cells[3].Value?.ToString() ?? "";
            string info = row.Cells[4].Value?.ToString() ?? "";

            EditPersonForm form = new EditPersonForm(name, tel, email, role, info);

            if (form.ShowDialog() == DialogResult.OK)
            {
                var newData = form.GetInputData();
                row.Cells[0].Value = newData.Name;
                row.Cells[1].Value = newData.Tel;
                row.Cells[2].Value = newData.Email;
                row.Cells[3].Value = newData.Role;
                row.Cells[4].Value = newData.Info;
            }
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            btnViewByRole.Click += btnViewByRole_Click;
        }

        // Sự kiện lọc dữ liệu DataGridView theo Role
        private void btnViewByRole_Click(object sender, EventArgs e)
        {
            string selectedRole = comboBox1.Text;
            
            // Xóa hết dữ liệu hiện có trên Grid
            dataGridView1.Rows.Clear();

            // Hiển thị lại các dòng có Role tương ứng từ Data Structure (List _peopleList)
            foreach (var person in _peopleList)
            {
                if (selectedRole == "All" || person.Role.Equals(selectedRole, System.StringComparison.OrdinalIgnoreCase))
                {
                    string info = ""; // Get base info based on inherited class type
                    if (person is Teacher t) info = $"Salary: {t.Salary}, Subj: {t.Subject1}, {t.Subject2}";
                    else if (person is Admin a) info = $"Salary: {a.Salary}, FullTime: {a.IsFullTime}";
                    else if (person is Student s) info = $"Subj: {s.Subject1}, {s.Subject2}, {s.Subject3}";

                    dataGridView1.Rows.Add(person.Name, person.Telephone, person.Email, person.Role, info);
                }
            }
        }
    }
}

using System;
using System.Windows.Forms;
using MySql.Data.MySqlClient;

namespace coursework
{
    public partial class Form1 : Form
    {
        // This list will act as the required data structure for holding objects of derived classes polymorphically
        private System.Collections.Generic.List<Person> _peopleList = new System.Collections.Generic.List<Person>();

        public Form1()
        {
            InitializeComponent();
            
            // Thiết lập ComboBox "Loc theo Role" trên màn hình chính
            comboBox1.Items.Clear();
            comboBox1.Items.Add("All"); // Thêm All để xem tất cả
            comboBox1.Items.Add("Teacher");
            comboBox1.Items.Add("Admin");
            comboBox1.Items.Add("Student");
            comboBox1.DropDownStyle = ComboBoxStyle.DropDownList;
            comboBox1.SelectedIndex = 0; // Mặc định chọn All
        }

        private void btnAddNew_Click(object sender, EventArgs e)
        {
            AddPersonForm form = new AddPersonForm();
            if (form.ShowDialog() == DialogResult.OK)
            {
                var data = form.GetInputData();
                Person newPerson = null;

                // Chuẩn hóa role giống với Combobox (Title Case)
                string role = data.Role;
                double salary = 0;
                double.TryParse(data.Info.Split(' ')[0], out salary); 

                if (role.Equals("Teacher", System.StringComparison.OrdinalIgnoreCase))
                {
                    newPerson = new Teacher(data.Name, data.Tel, data.Email, salary, "Subject1", "Subject2");
                    newPerson.Role = "Teacher";
                }
                else if (role.Equals("Admin", System.StringComparison.OrdinalIgnoreCase))
                {
                    newPerson = new Admin(data.Name, data.Tel, data.Email, salary, true, 40);
                    newPerson.Role = "Admin";
                }
                else 
                {
                    newPerson = new Student(data.Name, data.Tel, data.Email, "Subject1", "Subject2", "Subject3");
                    newPerson.Role = "Student";
                }

                _peopleList.Add(newPerson); 

                dataGridView1.Rows.Add(
                    newPerson.Name,
                    newPerson.Telephone,
                    newPerson.Email,
                    newPerson.Role,
                    data.Info 
                );
                
                SaveToMySQL(newPerson.Name, newPerson.Telephone, newPerson.Email, newPerson.Role, data.Info);
            }
        }

        private void btnEdit_Click(object sender, EventArgs e)
        {
            if (dataGridView1.CurrentRow == null) return;
            
            DataGridViewRow row = dataGridView1.CurrentRow;

            string name = row.Cells[0].Value?.ToString() ?? "";
            string tel = row.Cells[1].Value?.ToString() ?? "";
            string email = row.Cells[2].Value?.ToString() ?? "";
            string role = row.Cells[3].Value?.ToString() ?? "";
            string info = row.Cells[4].Value?.ToString() ?? "";

            EditPersonForm form = new EditPersonForm(name, tel, email, role, info);

            if (form.ShowDialog() == DialogResult.OK)
            {
                var newData = form.GetInputData();
                row.Cells[0].Value = newData.Name;
                row.Cells[1].Value = newData.Tel;
                row.Cells[2].Value = newData.Email;
                row.Cells[3].Value = newData.Role;
                row.Cells[4].Value = newData.Info;
            }
        }

        private string connectionString = "Server=localhost;Port=3306;Database=coursework;Uid=root;Pwd=;";

        private void Form1_Load(object sender, EventArgs e)
        {
            btnViewByRole.Click += btnViewByRole_Click;
            btnView.Click += btnView_Click;
            btnDelete.Click += btnDelete_Click;
            LoadDataFromDatabase();
        }

        private void LoadDataFromDatabase()
        {
            _peopleList.Clear();
            dataGridView1.Rows.Clear();

            try
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();
                    string query = "SELECT Name, Telephone, Email, Role, AdditionalInfo FROM Persons";
                    using (MySqlCommand cmd = new MySqlCommand(query, conn))
                    using (MySqlDataReader reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            string n = reader["Name"].ToString() ?? "";
                            string t = reader["Telephone"].ToString() ?? "";
                            string em = reader["Email"].ToString() ?? "";
                            string r = reader["Role"].ToString() ?? "";
                            string info = reader["AdditionalInfo"].ToString() ?? "";

                            Person p = null;
                            if (r.Equals("Teacher", StringComparison.OrdinalIgnoreCase))
                                p = new Teacher(n, t, em, 0, info, ""); // simplified
                            else if (r.Equals("Admin", StringComparison.OrdinalIgnoreCase))
                                p = new Admin(n, t, em, 0, true, 40); // simplified
                            else
                                p = new Student(n, t, em, info, "", ""); // simplified

                            p.Role = r;
                            _peopleList.Add(p);
                            dataGridView1.Rows.Add(p.Name, p.Telephone, p.Email, p.Role, info);
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("DB Load warning (If you haven't created the table yet, ignore): " + ex.Message);
            }
        }

        private void SaveToMySQL(string name, string tel, string email, string role, string info)
        {
            try
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();
                    string query = "INSERT INTO Persons (Name, Telephone, Email, Role, AdditionalInfo) VALUES (@n, @t, @e, @r, @i)";
                    using (MySqlCommand cmd = new MySqlCommand(query, conn))
                    {
                        cmd.Parameters.AddWithValue("@n", name);
                        cmd.Parameters.AddWithValue("@t", tel);
                        cmd.Parameters.AddWithValue("@e", email);
                        cmd.Parameters.AddWithValue("@r", role);
                        cmd.Parameters.AddWithValue("@i", info);
                        cmd.ExecuteNonQuery();
                    }
                }
            }
            catch { }
        }

        // Sự kiện lọc dữ liệu DataGridView theo Role
        private void btnViewByRole_Click(object sender, EventArgs e)
        {
            string selectedRole = comboBox1.Text;
            
            // Xóa hết dữ liệu hiện có trên Grid
            dataGridView1.Rows.Clear();

            // Hiển thị lại các dòng có Role tương ứng từ Data Structure (List _peopleList)
            foreach (var person in _peopleList)
            {
                if (selectedRole == "All" || string.Equals(person.Role, selectedRole, System.StringComparison.OrdinalIgnoreCase))
                {
                    string info = ""; // Get base info based on inherited class type
                    if (person is Teacher t) info = $"Salary: {t.Salary}, Subj: {t.Subject1}, {t.Subject2}";
                    else if (person is Admin a) info = $"Salary: {a.Salary}, FullTime: {a.IsFullTime}";
                    else if (person is Student s) info = $"Subj: {s.Subject1}, {s.Subject2}, {s.Subject3}";

                    dataGridView1.Rows.Add(person.Name, person.Telephone, person.Email, person.Role, info);
                }
            }
        }

        private void btnView_Click(object sender, EventArgs e)
        {
            comboBox1.SelectedIndex = 0; // Choose "All"
            btnViewByRole_Click(sender, e); // Reload grid
        }

        private void btnDelete_Click(object sender, EventArgs e)
        {
            if (dataGridView1.CurrentRow == null) return;

            DialogResult confirm = MessageBox.Show("Are you sure you want to delete this record?", "Delete Confirmation", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            if (confirm == DialogResult.Yes)
            {
                // Remove from underlying data list (_peopleList)
                int rowIndex = dataGridView1.CurrentRow.Index;
                if (rowIndex >= 0 && rowIndex < _peopleList.Count)
                {
                    _peopleList.RemoveAt(rowIndex); // Remove from list
                    dataGridView1.Rows.RemoveAt(rowIndex); // Remove from GridView
                }
            }
        }
    }
}

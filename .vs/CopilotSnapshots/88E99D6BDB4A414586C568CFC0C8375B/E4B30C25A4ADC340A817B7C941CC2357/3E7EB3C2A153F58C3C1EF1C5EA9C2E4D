        private void DeleteFromDatabase(int id)
        {
            string query = "DELETE FROM Person WHERE id = @id";

            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    MySqlCommand cmd = new MySqlCommand(query, conn);
                    cmd.Parameters.AddWithValue("@id", id);

                    int result = cmd.ExecuteNonQuery();
                  
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Lỗi khi xóa trong Database: " + ex.Message);
                }
            }
        }

        private void btnDelete_Click(object sender, EventArgs e)
        {
            if (dataGridView1.CurrentRow == null) return;

            DialogResult confirm = MessageBox.Show("Are you sure you want to delete this record?", "Delete Confirmation", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            if (confirm == DialogResult.Yes)
            {
                int idToDelete = Convert.ToInt32(dataGridView1.CurrentRow.Cells[0].Value);
                // 2. GỌI LỆNH XÓA TRONG DATABASE TRƯỚC
                DeleteFromDatabase(idToDelete);
                // Remove from underlying data list (_peopleList)
                int rowIndex = dataGridView1.CurrentRow.Index;
                if (rowIndex >= 0 && rowIndex < _peopleList.Count)
                {
                    _peopleList.RemoveAt(rowIndex);
                }
                dataGridView1.Rows.RemoveAt(rowIndex);

            }
        }
        }

        private void btnViewByRole_Click(object sender, EventArgs e)
        {
            string selectedRole = comboBox1.Text;
            
       
            dataGridView1.Rows.Clear();

            // Hi?n th? l?i các dòng có Role t??ng ?ng t? Data Structure (List _peopleList)
            foreach (var person in _peopleList)
            {
                bool isMatch = false;
                if (selectedRole == "All") isMatch = true;
                else if (selectedRole == "Teaching Staff" && person is Teacher) isMatch = true;
                else if (selectedRole == "Administration" && person is Admin) isMatch = true;
                else if (selectedRole == "Students" && person is Student) isMatch = true;
                else if (person.Role.Equals(selectedRole, System.StringComparison.OrdinalIgnoreCase)) isMatch = true;

                if (isMatch)
                {
                    string info = ""; // Get base info based on inherited class type
                    if (person is Teacher t) info = $"Salary: {t.Salary}, Subj: {t.Subject1}, {t.Subject2}";
                    else if (person is Admin a) info = $"Salary: {a.Salary}, {(a.IsFullTime ? "Full-Time" : "Part-Time")}, Hrs: {a.WorkingHours}";
                    else if (person is Student s) info = $"Subj: {s.Subject1}, {s.Subject2}, {s.Subject3}";

                    dataGridView1.Rows.Add(person.Id, person.Name, person.Telephone, person.Email, person.Role, info);
                }
            }
        }

        private void btnView_Click(object sender, EventArgs e)
